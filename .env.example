# .env.example — copy to .env and edit as needed.
# All settings have working defaults in app/core/config.py; override only when
# you need to deviate from the dev profile. Prefix every variable with HRBS_.

# ── PDF ingestion ────────────────────────────────────────────────────────────
HRBS_MAX_UPLOAD_SIZE_BYTES=52428800
HRBS_PDF_EXTRACTION_STRATEGY=layout

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev: SQLite via aiosqlite (file relative to the project root).
HRBS_DATABASE_URL=sqlite+aiosqlite:///./horseracing.db
# Production target: PostgreSQL via asyncpg.
# HRBS_DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/horseracing

# ── Logging ──────────────────────────────────────────────────────────────────
HRBS_LOG_LEVEL=INFO
# Pretty (key=value) in dev; flip to true for JSON in prod.
HRBS_LOG_JSON=false

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated allow-list. Default `*` is fine for local dev. In production,
# set to the Vercel frontend origin(s) so browsers can call this API.
# HRBS_CORS_ORIGINS=https://your-app.vercel.app,https://staging.your-app.vercel.app

# ── Inference models ─────────────────────────────────────────────────────────
# Where the FastAPI lifespan loads the trained artifact bundle.
# Override for tests or alternative installs.
# HRBS_MODELS_DIR=models/baseline_full

# ── Bankroll / Bet sizing (Phase 5 — overrideable at runtime) ────────────────
HRBS_BANKROLL_USD=10000.0
HRBS_KELLY_FRACTION=0.25
HRBS_MAX_BET_FRACTION=0.03
HRBS_CVAR_ALPHA=0.05
HRBS_MAX_DAILY_DRAWDOWN_PCT=0.10
