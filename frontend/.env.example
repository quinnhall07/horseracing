# FastAPI base URL for the typed API client (lib/api.ts).
# Defaults to http://localhost:8000 if unset.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Set to "true" to use mock data from lib/mock.ts when no backend is running
# (frontend-only demos, design iteration). Default is "false" — hit the API.
NEXT_PUBLIC_MOCK_API=false
